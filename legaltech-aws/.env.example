APP_ENV=local
APP_NAME=legaltech-aws
AWS_REGION=sa-east-1
AUTH_PROVIDER=dev_jwt

DATABASE_URL=postgresql://user:password@localhost:5432/legaltech

S3_DOCUMENTS_BUCKET=legaltech-documents-dev

SQS_TRIAGE_QUEUE_URL=http://localhost:4566/000000000000/legaltech-triage-queue
SQS_EXTERNAL_COLLECTION_QUEUE_URL=http://localhost:4566/000000000000/legaltech-external-collection-queue
SQS_DOCUMENT_PROCESSING_QUEUE_URL=http://localhost:4566/000000000000/legaltech-document-processing-queue
SQS_EMBEDDING_QUEUE_URL=http://localhost:4566/000000000000/legaltech-embedding-queue
SQS_CONTRACT_ANALYSIS_QUEUE_URL=http://localhost:4566/000000000000/legaltech-contract-analysis-queue
SQS_COMPLIANCE_QUEUE_URL=http://localhost:4566/000000000000/legaltech-compliance-queue
SQS_REPORT_QUEUE_URL=http://localhost:4566/000000000000/legaltech-report-queue

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=sa-east-1
COGNITO_ISSUER=
COGNITO_JWKS_URL=
COGNITO_ORGANIZATION_CLAIM=custom:organization_id
COGNITO_ROLE_CLAIM=custom:role
COGNITO_TOKEN_USE=id

DEV_JWT_ENABLED=true
DEV_JWT_SECRET=fictitious-local-dev-secret-32-bytes-minimum
DEV_JWT_ISSUER=legaltech-local-dev
DEV_JWT_AUDIENCE=legaltech-local-api

SECRETS_EXTERNAL_APIS_NAME=legaltech/dev/external-apis
OPENAI_API_SECRET_NAME=legaltech/dev/openai

LOG_LEVEL=INFO
