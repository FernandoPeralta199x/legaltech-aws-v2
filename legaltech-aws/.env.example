# Exemplo raiz ficticio para desenvolvimento local e referencia de variaveis.
# Nunca coloque secrets reais neste arquivo.

PROJECT_NAME=legaltech
ENVIRONMENT=local

APP_ENV=local
APP_NAME=legaltech-api
APP_VERSION=0.1.0
ENABLE_DOCS=true
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.0.102:3000

DATABASE_URL=postgresql+psycopg://legaltech:legaltech_dev@localhost:5432/legaltech

# Auth local. Permitido somente com APP_ENV=local.
AUTH_PROVIDER=dev_jwt
DEV_JWT_ENABLED=true
DEV_JWT_SECRET=fictitious-local-dev-secret-32-bytes-minimum
DEV_JWT_ISSUER=legaltech-local-dev
DEV_JWT_AUDIENCE=legaltech-local-api

# Cognito futuro. Preencher apenas com valores reais fora do Git.
COGNITO_REGION=sa-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=
COGNITO_JWKS_URL=
COGNITO_ORGANIZATION_CLAIM=custom:organization_id
COGNITO_ROLE_CLAIM=custom:role
COGNITO_TOKEN_USE=id

# AWS comum. Valores reais devem ficar em ambiente seguro.
AWS_ACCOUNT_ID=000000000000
AWS_REGION=sa-east-1
AWS_PROFILE=legaltech-local
AWS_ENDPOINT_URL=
DOMAIN_NAME=
ACM_CERTIFICATE_ARN=
CLOUDFRONT_DISTRIBUTION_ID=

# Storage de documentos.
STORAGE_BACKEND=local
LOCAL_UPLOAD_ROOT=storage/local_uploads
MAX_UPLOAD_SIZE_BYTES=10485760
S3_DOCUMENTS_BUCKET=legaltech-local-documents-placeholder
PRESIGNED_URL_EXPIRES_SECONDS=900

# Processamento local/mock e filas.
LOCAL_PROCESSING_MAX_TEXT_CHARS=50000
DOCUMENT_PROCESSING_MAX_ATTEMPTS=3
QUEUE_BACKEND=local
LOCAL_QUEUE_PATH=storage/local_queue/document_processing.jsonl
SQS_DOCUMENT_PROCESSING_QUEUE_URL=http://localhost:4566/000000000000/legaltech-local-document-processing
SQS_TRIAGE_QUEUE_URL=http://localhost:4566/000000000000/legaltech-local-triage
SQS_EXTERNAL_COLLECTION_QUEUE_URL=http://localhost:4566/000000000000/legaltech-local-external-collection
SQS_CONTRACT_ANALYSIS_QUEUE_URL=http://localhost:4566/000000000000/legaltech-local-contract-analysis
SQS_COMPLIANCE_QUEUE_URL=http://localhost:4566/000000000000/legaltech-local-compliance
SQS_REPORT_QUEUE_URL=http://localhost:4566/000000000000/legaltech-local-report

# Nomes logicos de secrets futuros. Nao sao valores de secrets.
SECRETS_EXTERNAL_APIS_NAME=legaltech/local/external-apis
OPENAI_API_SECRET_NAME=legaltech/local/openai

# Frontend publico. Nunca coloque secrets em NEXT_PUBLIC_*.
# Atenção: variáveis NEXT_PUBLIC_* são expostas no navegador. Nunca coloque secrets, tokens, senhas ou dados sensíveis nelas.
NEXT_PUBLIC_APP_NAME=LegalTech AWS V2
NEXT_PUBLIC_APP_ENV=local
# Desktop local: http://127.0.0.1:8000
# Teste mobile na rede local: http://192.168.0.102:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ENABLE_API_MOCK_FALLBACK=true
