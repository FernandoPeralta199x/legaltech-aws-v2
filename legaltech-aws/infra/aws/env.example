# Exemplo ficticio para planejamento AWS. Nao usar como credencial real.

PROJECT_NAME=legaltech
ENVIRONMENT=staging
AWS_ACCOUNT_ID=000000000000
AWS_REGION=sa-east-1
AWS_PROFILE=legaltech-staging

DOMAIN_NAME=staging.example.legaltech.local
ACM_CERTIFICATE_ARN=arn:aws:acm:sa-east-1:000000000000:certificate/example-placeholder
CLOUDFRONT_DISTRIBUTION_ID=EXAMPLE123456

APP_ENV=staging
APP_NAME=legaltech-api
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=https://staging.example.legaltech.local
AUTH_PROVIDER=cognito
DEV_JWT_ENABLED=false

DATABASE_URL=postgresql+psycopg://placeholder_user:placeholder_password@placeholder-rds.cluster.local:5432/legaltech

COGNITO_REGION=sa-east-1
COGNITO_USER_POOL_ID=sa-east-1_EXAMPLE
COGNITO_CLIENT_ID=example-client-id
COGNITO_ISSUER=https://cognito-idp.sa-east-1.amazonaws.com/sa-east-1_EXAMPLE
COGNITO_JWKS_URL=https://cognito-idp.sa-east-1.amazonaws.com/sa-east-1_EXAMPLE/.well-known/jwks.json
COGNITO_ORGANIZATION_CLAIM=custom:organization_id
COGNITO_ROLE_CLAIM=custom:role
COGNITO_TOKEN_USE=id

STORAGE_BACKEND=s3
S3_DOCUMENTS_BUCKET=legaltech-staging-documents
AWS_ENDPOINT_URL=
PRESIGNED_URL_EXPIRES_SECONDS=900

QUEUE_BACKEND=sqs
SQS_DOCUMENT_PROCESSING_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/000000000000/legaltech-staging-document-processing
SQS_TRIAGE_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/000000000000/legaltech-staging-triage
SQS_EXTERNAL_COLLECTION_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/000000000000/legaltech-staging-external-collection
SQS_CONTRACT_ANALYSIS_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/000000000000/legaltech-staging-contract-analysis
SQS_COMPLIANCE_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/000000000000/legaltech-staging-compliance
SQS_REPORT_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/000000000000/legaltech-staging-report

SECRETS_EXTERNAL_APIS_NAME=legaltech/staging/external-apis
OPENAI_API_SECRET_NAME=legaltech/staging/openai
